# =====================================================
# NeuroSolver - .gitignore
# =====================================================

# -------------------------------
# Python
# -------------------------------
__pycache__/
*.py[cod]
*$py.class

# -------------------------------
# Virtual Environments
# -------------------------------
.venv/
venv/
env/
ENV/

# -------------------------------
# VS Code
# -------------------------------
.vscode/

# -------------------------------
# PyCharm
# -------------------------------
.idea/

# -------------------------------
# Jupyter Notebook
# -------------------------------
.ipynb_checkpoints/

# -------------------------------
# Operating System Files
# -------------------------------
.DS_Store
Thumbs.db

# -------------------------------
# Dataset (Downloaded Automatically)
# -------------------------------
data/

# If you want to keep sample images,
# uncomment the next line:
#!data/sample_images/

# -------------------------------
# Training Logs
# -------------------------------
logs/

# -------------------------------
# Generated Outputs
# -------------------------------
outputs/

# -------------------------------
# Temporary Files
# -------------------------------
*.tmp
*.temp

# -------------------------------
# Python Build Files
# -------------------------------
build/
dist/
*.egg-info/

# -------------------------------
# Model Checkpoints
# -------------------------------
# Uncomment if you DON'T want to upload trained models
# checkpoints/
# src/checkpoints/

# -------------------------------
# Environment Variables
# -------------------------------
.env

# -------------------------------
# pytest Cache
# -------------------------------
.pytest_cache/

# -------------------------------
# mypy Cache
# -------------------------------
.mypy_cache/

# -------------------------------
# Coverage Reports
# -------------------------------
.coverage
htmlcov/